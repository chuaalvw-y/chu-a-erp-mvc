# Auto detect text files and perform LF normalization
* text=auto

# Binary documents and assets — never apply EOL normalization
*.pdf  binary
*.docx binary
*.doc  binary
*.xlsx binary
*.xls  binary
*.pptx binary
*.ppt  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
