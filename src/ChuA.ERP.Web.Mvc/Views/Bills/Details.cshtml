@model BillDto
@{
    ViewData["Title"] = Model.BillNumber;
    var canApprove = string.Equals(Model.Status, "PendingApproval", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.Status, "Draft", StringComparison.OrdinalIgnoreCase);
    var canPay = string.Equals(Model.Status, "Approved", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(Model.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Bill @Model.BillNumber</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="BillCreate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="BillCreate">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Bill id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Vendor id</dt><dd class="col-sm-9"><code>@Model.VendorId</code></dd>
    <dt class="col-sm-3">Bill number</dt><dd class="col-sm-9">@Model.BillNumber</dd>
    <dt class="col-sm-3">Bill date</dt><dd class="col-sm-9">@Model.BillDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Due date</dt><dd class="col-sm-9">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.CurrencyCode</dd>
    <dt class="col-sm-3">Total amount</dt><dd class="col-sm-9">@Html.Money(Model.TotalAmount)</dd>
    <dt class="col-sm-3">Outstanding</dt><dd class="col-sm-9">@Html.Money(Model.OutstandingBalance)</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
    <dt class="col-sm-3">Payment status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.PaymentStatus)</dd>
</dl>

<div class="d-flex gap-2 mb-4">
    @if (canApprove)
    {
        <a class="btn btn-success btn-lg" asp-action="Approve" asp-route-id="@Model.Id" asp-authorize-policy="BillApprove">Approve bill</a>
    }
    @if (canPay)
    {
        <a class="btn btn-primary btn-lg" asp-action="Pay" asp-route-id="@Model.Id" asp-authorize-policy="BillPay">Record payment</a>
    }
</div>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
