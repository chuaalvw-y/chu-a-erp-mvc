@model ChuA.ERP.Web.Mvc.ViewModels.Bills.BillListViewModel
@{
    ViewData["Title"] = "Bills";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Bills</h1>
    <div>
        <a asp-action="AwaitingApproval" class="btn btn-outline-info" asp-authorize-policy="BillRead">Awaiting approval</a>
        <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="BillCreate">+ New bill</a>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search bill number..." />
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
            <option value="PendingApproval" selected="@(Model.Status == "PendingApproval")">Pending approval</option>
            <option value="Approved" selected="@(Model.Status == "Approved")">Approved</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="paymentStatus" class="form-select">
            <option value="">All payment statuses</option>
            <option value="Unpaid" selected="@(Model.PaymentStatus == "Unpaid")">Unpaid</option>
            <option value="PartiallyPaid" selected="@(Model.PaymentStatus == "PartiallyPaid")">Partially paid</option>
            <option value="Paid" selected="@(Model.PaymentStatus == "Paid")">Paid</option>
        </select>
    </div>
    <div class="col-md-3">
        <input type="text" name="vendorId" value="@(Model.VendorId?.ToString())" class="form-control" placeholder="Vendor id (optional)" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No bills match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Bill #</th><th>Bill date</th><th>Due date</th><th class="text-end">Total</th><th class="text-end">Outstanding</th><th>Status</th><th>Payment</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var b in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@b.Id">@b.BillNumber</a></td>
                    <td>@b.BillDate.ToString("yyyy-MM-dd")</td>
                    <td>@b.DueDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@Html.Money(b.TotalAmount)</td>
                    <td class="text-end">@Html.Money(b.OutstandingBalance)</td>
                    <td>@Html.StatusBadge(b.Status)</td>
                    <td>@Html.StatusBadge(b.PaymentStatus)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@b.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@b.Id" asp-authorize-policy="BillCreate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
