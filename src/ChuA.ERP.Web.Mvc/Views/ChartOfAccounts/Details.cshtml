@model ChartOfAccountDto
@{
    ViewData["Title"] = Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Name <small class="text-muted">@Model.AccountCode</small></h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="ChartOfAccountCreate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="ChartOfAccountCreate">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Account id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Company id</dt><dd class="col-sm-9"><code>@Model.CompanyId</code></dd>
    <dt class="col-sm-3">Account code</dt><dd class="col-sm-9">@Model.AccountCode</dd>
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Account type</dt><dd class="col-sm-9">@Html.StatusBadge(Model.AccountType)</dd>
    <dt class="col-sm-3">Normal balance</dt><dd class="col-sm-9">@Model.NormalBalance</dd>
    <dt class="col-sm-3">Postable</dt><dd class="col-sm-9">@(Model.IsPostable ? "Yes" : "No")</dd>
    <dt class="col-sm-3">Parent account</dt><dd class="col-sm-9">@(Model.ParentAccountId is null ? "—" : Model.ParentAccountId.ToString())</dd>
    <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.CurrencyCode</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
