@model ChuA.ERP.Web.Mvc.ViewModels.ChartOfAccounts.ChartOfAccountListViewModel
@{
    ViewData["Title"] = "Chart of accounts";
    var types = new[] { "Asset", "Liability", "Equity", "Revenue", "Expense" };
}

@* "New account" link is the no-JS fallback (navigates to /ChartOfAccounts/Create). chua-coa.js
   intercepts clicks on .js-coa-create and fetches the modal partial instead. *@
<partial name="_PageHeader" model='@(new PageHeaderViewModel {
    Title = "Chart of accounts",
    Actions = new[]
    {
        new PageHeaderActionViewModel
        {
            Text = "New account",
            Url = Url.Action("Create") ?? "#",
            CssClass = "btn btn-primary js-coa-create",
            Policy = AuthorizationPolicies.ChartOfAccountCreate,
            IconCssClass = "bi bi-plus-lg",
        }
    }
})' />

<form id="coa-filter-form" method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search accounts..." autocomplete="off" />
    </div>
    <div class="col-md-3">
        <select name="accountType" class="form-select">
            <option value="">All types</option>
            @foreach (var t in types)
            {
                if (string.Equals(Model.AccountType, t, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@t" selected>@t</option>
                }
                else
                {
                    <option value="@t">@t</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div id="coa-rows-container"
     data-rows-url="@Url.Action("IndexPartial", "ChartOfAccounts")"
     data-current-search="@(Model.Search ?? string.Empty)"
     data-current-account-type="@(Model.AccountType ?? string.Empty)">
    <partial name="_ChartOfAccountRowsPartial" model="Model" />
</div>

@* Modal host - chua-coa.js injects the modal partial here. *@
<div class="modal fade" id="coa-modal-host" tabindex="-1" aria-hidden="true" aria-labelledby="coa-modal-host"></div>

@section Scripts {
    <script src="~/js/chua-coa.js" asp-append-version="true"></script>
}
