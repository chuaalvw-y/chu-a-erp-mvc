@model ChuA.ERP.Web.Mvc.ViewModels.ChartOfAccounts.ChartOfAccountListViewModel
@{
    ViewData["Title"] = "Chart of accounts";
    var types = new[] { "Asset", "Liability", "Equity", "Revenue", "Expense" };
}
<partial name="_PageHeader" model='@(new PageHeaderViewModel { Title = "Chart of accounts", Actions = new[] { new PageHeaderActionViewModel { Text = "New account", Url = Url.Action("Create")!, Policy = AuthorizationPolicies.ChartOfAccountCreate, IconCssClass = "bi bi-plus-lg" } } })' />

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search accounts..." />
    </div>
    <div class="col-md-3">
        <select name="accountType" class="form-select" onchange="this.form.submit()">
            <option value="">All types</option>
            @foreach (var t in types)
            {
                if (string.Equals(Model.AccountType, t, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@t" selected>@t</option>
                }
                else
                {
                    <option value="@t">@t</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No chart-of-accounts entries match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Code</th><th>Name</th><th>Type</th><th>Normal balance</th><th>Postable</th><th>Currency</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var c in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@c.Id">@c.AccountCode</a></td>
                    <td>@c.Name</td>
                    <td>@Html.StatusBadge(c.AccountType)</td>
                    <td>@c.NormalBalance</td>
                    <td>@(c.IsPostable ? "Yes" : "No")</td>
                    <td>@c.CurrencyCode</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id" asp-authorize-policy="ChartOfAccountUpdate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
