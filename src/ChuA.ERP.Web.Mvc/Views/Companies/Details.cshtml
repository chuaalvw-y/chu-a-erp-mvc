@model CompanyDto
@{
    ViewData["Title"] = Model.Name;
    var addr = Model.RegisteredAddress;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Name <small class="text-muted">@Model.Code</small></h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin">Delete</a>
    </div>
</div>

<h2 class="h5 mt-4">Identity</h2>
<dl class="row">
    <dt class="col-sm-3">Company id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Code</dt><dd class="col-sm-9">@Model.Code</dd>
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Legal name</dt><dd class="col-sm-9">@(Model.LegalName ?? "—")</dd>
    <dt class="col-sm-3">Tax id</dt><dd class="col-sm-9">@(Model.TaxIdentificationNumber ?? "—")</dd>
    <dt class="col-sm-3">Registration #</dt><dd class="col-sm-9">@(Model.RegistrationNumber ?? "—")</dd>
    <dt class="col-sm-3">Base currency</dt><dd class="col-sm-9">@Model.BaseCurrencyCode</dd>
</dl>

<h2 class="h5 mt-4">Registered address</h2>
<dl class="row">
    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@addr.Line1, @addr.City, @addr.State @addr.PostalCode, @addr.CountryCode</dd>
</dl>

<h2 class="h5 mt-4">Contact</h2>
<dl class="row">
    <dt class="col-sm-3">Phone</dt><dd class="col-sm-9">@(Model.Phone ?? "—")</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@(Model.Email ?? "—")</dd>
    <dt class="col-sm-3">Website</dt><dd class="col-sm-9">@(Model.Website ?? "—")</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
