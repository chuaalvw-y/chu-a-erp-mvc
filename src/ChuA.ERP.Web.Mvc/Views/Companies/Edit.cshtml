@model ChuA.ERP.Web.Mvc.ViewModels.Companies.CompanyFormViewModel
@{
    ViewData["Title"] = "Edit company";
}
<h1 class="h3 mb-4">Edit company</h1>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_Form" model="Model" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
