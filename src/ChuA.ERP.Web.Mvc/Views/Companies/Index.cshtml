@model ChuA.ERP.Web.Mvc.ViewModels.Companies.CompanyListViewModel
@{
    ViewData["Title"] = "Companies";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Companies</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-role="SystemAdmin">+ New company</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No companies match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Code</th><th>Name</th><th>Base currency</th><th>City / Country</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var c in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@c.Id">@c.Code</a></td>
                    <td>@c.Name</td>
                    <td>@c.BaseCurrencyCode</td>
                    <td>@c.RegisteredAddress.City, @c.RegisteredAddress.CountryCode</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id" asp-authorize-role="SystemAdmin">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
