@model CustomerDto
@{
    ViewData["Title"] = Model.LegalName;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.LegalName <small class="text-muted">@Model.CustomerCode</small></h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="CustomerUpdate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="CustomerDelete">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Customer id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Company id</dt><dd class="col-sm-9"><code>@Model.CompanyId</code></dd>
    <dt class="col-sm-3">Customer code</dt><dd class="col-sm-9">@Model.CustomerCode</dd>
    <dt class="col-sm-3">Legal name</dt><dd class="col-sm-9">@Model.LegalName</dd>
    <dt class="col-sm-3">Default currency</dt><dd class="col-sm-9">@Model.DefaultCurrencyCode</dd>
    <dt class="col-sm-3">Payment terms</dt><dd class="col-sm-9">@Model.PaymentTermsDays days</dd>
    <dt class="col-sm-3">Credit limit</dt><dd class="col-sm-9">@Html.Money(Model.CreditLimit)</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.IsBlocked ? "Blocked" : "Active")</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
