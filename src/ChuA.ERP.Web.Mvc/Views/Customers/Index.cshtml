@model ChuA.ERP.Web.Mvc.ViewModels.Customers.CustomerListViewModel
@{
    ViewData["Title"] = "Customers";
}

@* "New customer" link is the no-JS fallback (navigates to /Customers/Create). chua-customers.js
   intercepts clicks on .js-customer-create and fetches the modal partial instead. *@
<partial name="_PageHeader" model='@(new PageHeaderViewModel {
    Title = "Customers",
    Actions = new[]
    {
        new PageHeaderActionViewModel
        {
            Text = "New customer",
            Url = Url.Action("Create") ?? "#",
            CssClass = "btn btn-primary js-customer-create",
            Policy = AuthorizationPolicies.CustomerCreate,
            IconCssClass = "bi bi-plus-lg",
        }
    }
})' />

<partial name="_SearchBox" model="Model.Search" />

<div id="customers-rows-container"
     data-rows-url="@Url.Action("IndexPartial", "Customers")"
     data-current-search="@(Model.Search ?? string.Empty)">
    <partial name="_CustomerRowsPartial" model="Model" />
</div>

@* Modal host - chua-customers.js injects the modal partial here and uses Bootstrap to show it. *@
<div class="modal fade" id="customer-modal-host" tabindex="-1" aria-hidden="true" aria-labelledby="customer-modal-host"></div>

@section Scripts {
    <script src="~/js/chua-customers.js" asp-append-version="true"></script>
}
