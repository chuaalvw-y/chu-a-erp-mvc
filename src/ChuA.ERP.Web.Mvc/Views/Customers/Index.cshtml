@model ChuA.ERP.Web.Mvc.ViewModels.Customers.CustomerListViewModel
@{
    ViewData["Title"] = "Customers";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Customers</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="CustomerCreate">+ New customer</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No customers match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Code</th><th>Legal name</th><th>Currency</th><th>Credit limit</th><th>Terms</th><th>Status</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var c in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@c.Id">@c.CustomerCode</a></td>
                    <td>@c.LegalName</td>
                    <td>@c.DefaultCurrencyCode</td>
                    <td>@Html.Money(c.CreditLimit)</td>
                    <td>@c.PaymentTermsDays days</td>
                    <td>@Html.StatusBadge(c.IsBlocked ? "Blocked" : "Active")</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id" asp-authorize-policy="CustomerUpdate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
