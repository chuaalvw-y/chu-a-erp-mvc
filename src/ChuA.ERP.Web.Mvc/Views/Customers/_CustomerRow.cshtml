    Single-row partial. Used both inside _CustomerRowsPartial (the full table body) and as
    the response of /Customers/RowPartial when the JS layer needs to refresh exactly one
    row after a successful modal save.
*@

@model ChuA.ERP.Web.Mvc.Contracts.Dtos.CustomerDto

<tr id="customer-row-@Model.Id" data-customer-id="@Model.Id">
    <td><a asp-action="Details" asp-route-id="@Model.Id">@Model.CustomerCode</a></td>
    <td>@Model.LegalName</td>
    <td>@Model.DefaultCurrencyCode</td>
    <td>@Html.Money(Model.CreditLimit)</td>
    <td>@Model.PaymentTermsDays days</td>
    <td>@Html.StatusBadge(Model.IsBlocked ? "Blocked" : "Active")</td>
    <td class="actions">
        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">View</a>
        <button type="button"
                class="btn btn-sm btn-outline-primary js-customer-edit"
                data-customer-id="@Model.Id"
                data-modal-url="@Url.Action("EditModal", "Customers", new { id = Model.Id })"
                asp-authorize-policy="customer:update">
            Edit
        </button>
    </td>
</tr>
