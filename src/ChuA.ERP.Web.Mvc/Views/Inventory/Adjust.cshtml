@model ChuA.ERP.Web.Mvc.ViewModels.Inventory.AdjustInventoryFormViewModel
@{
    ViewData["Title"] = "Adjust inventory";
    var item = ViewData["Item"] as ItemDto;
}
<h1 class="h3 mb-4 text-warning">Adjust inventory</h1>

<div class="alert alert-warning">
    <strong>Warning:</strong> Delta values may be <em>negative</em> to reduce stock. Adjustments are
    irreversible and posted as an immediate inventory movement. Double-check the warehouse, UoM and
    reason before submitting.
</div>

@if (item is not null)
{
    <dl class="row">
        <dt class="col-sm-3">Item</dt><dd class="col-sm-9">@item.Name <small class="text-muted">@item.Sku</small></dd>
        <dt class="col-sm-3">Default UoM</dt><dd class="col-sm-9">@item.DefaultUnitOfMeasure</dd>
    </dl>
}

<form asp-action="Adjust" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <input type="hidden" asp-for="Id" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="WarehouseId" class="form-label"></label>
            <input asp-for="WarehouseId" class="form-control" placeholder="Warehouse GUID" />
            <span asp-validation-for="WarehouseId" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="DeltaValue" class="form-label"></label>
            <input asp-for="DeltaValue" type="number" step="0.0001" class="form-control" />
            <span asp-validation-for="DeltaValue" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="DeltaUnitOfMeasure" class="form-label"></label>
            <input asp-for="DeltaUnitOfMeasure" class="form-control" maxlength="20" />
            <span asp-validation-for="DeltaUnitOfMeasure" class="text-danger"></span>
        </div>
        <div class="col-md-12">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control" rows="2" maxlength="200"></textarea>
            <span asp-validation-for="Reason" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-warning">Record adjustment</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
