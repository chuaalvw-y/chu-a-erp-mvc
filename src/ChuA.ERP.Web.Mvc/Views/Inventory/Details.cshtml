@model ItemDto
@{
    ViewData["Title"] = Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Name <small class="text-muted">@Model.Sku</small></h1>
    <div>
        <a class="btn btn-outline-warning" asp-action="Adjust" asp-route-id="@Model.Id" asp-authorize-policy="InventoryAdjust">Adjust</a>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="InventoryUpdate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="InventoryDelete">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Item id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Company id</dt><dd class="col-sm-9"><code>@Model.CompanyId</code></dd>
    <dt class="col-sm-3">SKU</dt><dd class="col-sm-9">@Model.Sku</dd>
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Default UoM</dt><dd class="col-sm-9">@Model.DefaultUnitOfMeasure</dd>
    <dt class="col-sm-3">Stocked</dt><dd class="col-sm-9">@(Model.IsStocked ? "Yes" : "No")</dd>
    <dt class="col-sm-3">Reorder point</dt><dd class="col-sm-9">@(Model.ReorderPoint?.ToString("N2") ?? "—")</dd>
</dl>

<div class="card mt-3">
    <div class="card-header">Check warehouse balance</div>
    <div class="card-body">
        <form asp-action="Balance" method="get" class="row g-2 align-items-end">
            <input type="hidden" name="itemId" value="@Model.Id" />
            <div class="col-md-6">
                <label class="form-label" for="warehouseId">Warehouse id</label>
                <input type="text" id="warehouseId" name="warehouseId" class="form-control" placeholder="Warehouse GUID" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary">Look up balance</button>
            </div>
        </form>
    </div>
</div>

<a asp-action="Index" class="btn btn-link mt-3">&larr; Back to list</a>
