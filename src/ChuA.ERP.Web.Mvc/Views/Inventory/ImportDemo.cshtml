@{
    ViewData["Title"] = "Import items";
}
@*
    Long-running operation example: a CSV import that streams rows server-side.
    The UI uses the full-page overlay (ChuALoading.fullPage) with a progress bar
    and a Cancel button. Because there's no real import endpoint yet, the page
    simulates progress in JavaScript — when the API gains a chunked endpoint
    (SSE / WebSocket), replace the setInterval below with the real stream.
*@

<h1 class="h3 mb-4">Import inventory items</h1>
<p class="text-muted">Upload a CSV with item SKUs and metadata. The import runs server-side and reports progress.</p>

<form id="import-form" data-loading-skip class="card p-4" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="import-file" class="form-label">CSV file</label>
        <input type="file" id="import-file" name="file" accept=".csv" class="form-control" required />
    </div>
    <div>
        <button type="submit" class="btn btn-primary">Start import</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

<div id="import-summary" class="mt-3" hidden role="status" aria-live="polite"></div>

@section Scripts {
<script>
    (function () {
        var form = document.getElementById('import-form');
        var summary = document.getElementById('import-summary');
        var ticker = null;
        var cancelled = false;

        form.addEventListener('submit', function (evt) {
            evt.preventDefault();
            cancelled = false;
            summary.setAttribute('hidden', '');

            ChuALoading.fullPage.show({
                message: 'Importing items...',
                percent: 0,
                cancellable: true,
                onCancel: function () {
                    cancelled = true;
                    if (ticker) clearInterval(ticker);
                    ChuALoading.fullPage.hide();
                    summary.textContent = 'Import cancelled. No rows were saved.';
                    summary.className = 'alert alert-warning';
                    summary.removeAttribute('hidden');
                }
            });

            // Simulated progress — replace with real chunked progress from API.
            var pct = 0;
            ticker = setInterval(function () {
                if (cancelled) return;
                pct += Math.random() * 8 + 2;
                if (pct >= 100) {
                    pct = 100;
                    clearInterval(ticker);
                    ChuALoading.fullPage.update({ percent: 100, message: 'Finalising...' });
                    setTimeout(function () {
                        ChuALoading.fullPage.hide();
                        summary.textContent = 'Import complete. 1,248 items processed, 0 errors.';
                        summary.className = 'alert alert-success';
                        summary.removeAttribute('hidden');
                    }, 400);
                } else {
                    ChuALoading.fullPage.update({
                        percent: pct,
                        message: 'Importing items... (' + Math.round(pct * 12.48) + ' of 1,248 rows)'
                    });
                }
            }, 350);
        });
    })();
</script>
}
