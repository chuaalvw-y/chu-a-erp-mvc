@model ChuA.ERP.Web.Mvc.ViewModels.Inventory.InventoryListViewModel
@{
    ViewData["Title"] = "Inventory";
}

@* "New item" link is the no-JS fallback (navigates to /Inventory/Create). chua-inventory.js
   intercepts clicks on .js-item-create and fetches the modal partial instead. *@
<partial name="_PageHeader" model='@(new PageHeaderViewModel {
    Title = "Inventory",
    Actions = new[]
    {
        new PageHeaderActionViewModel
        {
            Text = "New item",
            Url = Url.Action("Create") ?? "#",
            CssClass = "btn btn-primary js-item-create",
            Policy = AuthorizationPolicies.InventoryCreate,
            IconCssClass = "bi bi-plus-lg",
        }
    }
})' />

<partial name="_SearchBox" model="Model.Search" />

<div id="items-rows-container"
     data-rows-url="@Url.Action("IndexPartial", "Inventory")"
     data-current-search="@(Model.Search ?? string.Empty)">
    <partial name="_ItemRowsPartial" model="Model" />
</div>

@* Modal host - chua-inventory.js injects the modal partial here. *@
<div class="modal fade" id="item-modal-host" tabindex="-1" aria-hidden="true" aria-labelledby="item-modal-host"></div>

@section Scripts {
    <script src="~/js/chua-inventory.js" asp-append-version="true"></script>
}
