@model ChuA.ERP.Web.Mvc.ViewModels.Inventory.InventoryListViewModel
@{
    ViewData["Title"] = "Inventory";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Inventory</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="InventoryCreate">+ New item</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No items match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>SKU</th><th>Name</th><th>UoM</th><th>Stocked</th><th>Reorder point</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var item in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@item.Id">@item.Sku</a></td>
                    <td>@item.Name</td>
                    <td>@item.DefaultUnitOfMeasure</td>
                    <td>@(item.IsStocked ? "Yes" : "No")</td>
                    <td>@(item.ReorderPoint?.ToString("N2") ?? "—")</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id" asp-authorize-policy="InventoryCreate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
