@model ChuA.ERP.Web.Mvc.ViewModels.Invoices.InvoicePaymentFormViewModel
@{
    ViewData["Title"] = "Apply payment";
    var invoice = ViewData["Invoice"] as InvoiceDto;
}
<h1 class="h3 mb-4">Apply customer payment</h1>

@if (invoice is not null)
{
    <dl class="row">
        <dt class="col-sm-3">Invoice number</dt><dd class="col-sm-9">@invoice.InvoiceNumber</dd>
        <dt class="col-sm-3">Total</dt><dd class="col-sm-9">@Html.Money(invoice.TotalAmount)</dd>
        <dt class="col-sm-3">Outstanding</dt><dd class="col-sm-9">@Html.Money(invoice.OutstandingBalance)</dd>
        <dt class="col-sm-3">Payment status</dt><dd class="col-sm-9">@Html.StatusBadge(invoice.PaymentStatus)</dd>
    </dl>
}

<form asp-action="ApplyPayment" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="PaymentDate" class="form-label"></label>
            <input asp-for="PaymentDate" type="date" class="form-control" />
            <span asp-validation-for="PaymentDate" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Amount" class="form-label"></label>
            <input asp-for="Amount" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="CurrencyCode" class="form-label"></label>
            <input asp-for="CurrencyCode" class="form-control" maxlength="3" />
            <span asp-validation-for="CurrencyCode" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="PaymentMethod" class="form-label"></label>
            <input asp-for="PaymentMethod" class="form-control" />
            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
        </div>
        <div class="col-md-12">
            <label asp-for="Reference" class="form-label"></label>
            <input asp-for="Reference" class="form-control" />
            <span asp-validation-for="Reference" class="text-danger"></span>
        </div>
    </div>
    <input type="hidden" asp-for="Id" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Apply payment</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
