@model InvoiceDto
@{
    ViewData["Title"] = Model.InvoiceNumber;
    var canApply = !string.Equals(Model.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Invoice @Model.InvoiceNumber</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="invoice:update">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="invoice:delete">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Invoice id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Customer id</dt><dd class="col-sm-9"><code>@Model.CustomerId</code></dd>
    <dt class="col-sm-3">Invoice number</dt><dd class="col-sm-9">@Model.InvoiceNumber</dd>
    <dt class="col-sm-3">Invoice date</dt><dd class="col-sm-9">@Model.InvoiceDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Due date</dt><dd class="col-sm-9">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.CurrencyCode</dd>
    <dt class="col-sm-3">Total amount</dt><dd class="col-sm-9">@Html.Money(Model.TotalAmount)</dd>
    <dt class="col-sm-3">Outstanding</dt><dd class="col-sm-9">@Html.Money(Model.OutstandingBalance)</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
    <dt class="col-sm-3">Payment status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.PaymentStatus)</dd>
</dl>

@if (Model.Lines?.Count > 0)
{
    <h2 class="h5 mt-4">Lines</h2>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Description</th><th>Quantity</th><th>Unit price</th><th>Total</th><th>Revenue account</th></tr></thead>
            <tbody>
            @foreach (var line in Model.Lines)
            {
                <tr>
                    <td>@line.Description</td>
                    <td>@line.Quantity.Value @line.Quantity.UnitOfMeasure</td>
                    <td>@Html.Money(line.UnitPrice)</td>
                    <td>@Html.Money(line.LineTotal)</td>
                    <td><code>@line.RevenueAccountId</code></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<div class="d-flex gap-2 mb-4">
    @if (canApply)
    {
        <a class="btn btn-primary btn-lg" asp-action="ApplyPayment" asp-route-id="@Model.Id" asp-authorize-policy="invoice:apply-payment">Apply payment</a>
    }
</div>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
