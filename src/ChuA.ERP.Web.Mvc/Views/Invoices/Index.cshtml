@model ChuA.ERP.Web.Mvc.ViewModels.Invoices.InvoiceListViewModel
@{
    ViewData["Title"] = "Invoices";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Invoices</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="InvoiceCreate">+ New invoice</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search invoice number..." />
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
            <option value="Open" selected="@(Model.Status == "Open")">Open</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="paymentStatus" class="form-select">
            <option value="">All payment statuses</option>
            <option value="Unpaid" selected="@(Model.PaymentStatus == "Unpaid")">Unpaid</option>
            <option value="PartiallyPaid" selected="@(Model.PaymentStatus == "PartiallyPaid")">Partially paid</option>
            <option value="Paid" selected="@(Model.PaymentStatus == "Paid")">Paid</option>
        </select>
    </div>
    <div class="col-md-3">
        <input type="text" name="customerId" value="@(Model.CustomerId?.ToString())" class="form-control" placeholder="Customer id (optional)" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No invoices match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Invoice #</th><th>Invoice date</th><th>Due date</th><th class="text-end">Total</th><th class="text-end">Outstanding</th><th>Status</th><th>Payment</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var inv in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@inv.Id">@inv.InvoiceNumber</a></td>
                    <td>@inv.InvoiceDate.ToString("yyyy-MM-dd")</td>
                    <td>@inv.DueDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@Html.Money(inv.TotalAmount)</td>
                    <td class="text-end">@Html.Money(inv.OutstandingBalance)</td>
                    <td>@Html.StatusBadge(inv.Status)</td>
                    <td>@Html.StatusBadge(inv.PaymentStatus)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@inv.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@inv.Id" asp-authorize-policy="InvoiceCreate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
