@model ChuA.ERP.Web.Mvc.ViewModels.Invoices.InvoiceFormViewModel
<partial name="_ValidationSummary" />
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="CustomerId" class="form-label"></label>
        <input asp-for="CustomerId" class="form-control" />
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="InvoiceNumber" class="form-label"></label>
        <input asp-for="InvoiceNumber" class="form-control" />
        <span asp-validation-for="InvoiceNumber" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="CurrencyCode" class="form-label"></label>
        <input asp-for="CurrencyCode" class="form-control" maxlength="3" />
        <span asp-validation-for="CurrencyCode" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="InvoiceDate" class="form-label"></label>
        <input asp-for="InvoiceDate" type="date" class="form-control" />
        <span asp-validation-for="InvoiceDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>
</div>

<h2 class="h5 mt-4">Lines</h2>
<div class="table-responsive">
    <table class="table table-sm align-middle" id="lines">
        <thead>
            <tr>
                <th style="min-width:220px;">Description</th>
                <th style="width:90px;">Qty</th>
                <th style="width:90px;">Unit</th>
                <th style="width:130px;">Unit price</th>
                <th style="width:90px;">Currency</th>
                <th style="width:240px;">Revenue account id</th>
                <th style="width:80px;"></th>
            </tr>
        </thead>
        <tbody>
        @for (int i = 0; i < Model.Lines.Count; i++)
        {
            <tr class="line-row">
                <td>
                    <input name="Lines[@i].Description" value="@Model.Lines[i].Description" class="form-control" />
                </td>
                <td>
                    <input name="Lines[@i].QuantityValue" value="@Model.Lines[i].QuantityValue" type="number" step="0.01" class="form-control" />
                </td>
                <td>
                    <input name="Lines[@i].QuantityUnitOfMeasure" value="@Model.Lines[i].QuantityUnitOfMeasure" class="form-control" maxlength="20" />
                </td>
                <td>
                    <input name="Lines[@i].UnitPriceAmount" value="@Model.Lines[i].UnitPriceAmount" type="number" step="0.01" class="form-control" />
                </td>
                <td>
                    <input name="Lines[@i].UnitPriceCurrencyCode" value="@Model.Lines[i].UnitPriceCurrencyCode" class="form-control" maxlength="3" />
                </td>
                <td>
                    <input name="Lines[@i].RevenueAccountId" value="@(Model.Lines[i].RevenueAccountId?.ToString())" class="form-control" placeholder="(optional)" />
                </td>
                <td class="text-end">
                    <button type="button" class="btn btn-sm btn-outline-danger remove-line">Remove</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<button type="button" class="btn btn-outline-secondary btn-sm" id="add-line">+ Add line</button>

<input type="hidden" asp-for="Id" />

<script>
(function () {
    var table = document.getElementById('lines');
    var tbody = table.querySelector('tbody');

    function renumber() {
        var rows = tbody.querySelectorAll('tr.line-row');
        rows.forEach(function (row, idx) {
            row.querySelectorAll('input').forEach(function (input) {
                var name = input.getAttribute('name');
                if (!name) return;
                input.setAttribute('name', name.replace(/Lines\[\d+\]/, 'Lines[' + idx + ']'));
            });
        });
    }

    function wireRemove(row) {
        var btn = row.querySelector('.remove-line');
        if (!btn) return;
        btn.addEventListener('click', function () {
            if (tbody.querySelectorAll('tr.line-row').length <= 1) return;
            row.remove();
            renumber();
        });
    }

    tbody.querySelectorAll('tr.line-row').forEach(wireRemove);

    document.getElementById('add-line').addEventListener('click', function () {
        var rows = tbody.querySelectorAll('tr.line-row');
        var last = rows[rows.length - 1];
        var clone = last.cloneNode(true);
        clone.querySelectorAll('input').forEach(function (input) {
            if (input.type === 'number') input.value = '';
            else if (input.name && input.name.endsWith('.QuantityUnitOfMeasure')) input.value = 'EA';
            else if (input.name && input.name.endsWith('.UnitPriceCurrencyCode')) input.value = (document.querySelector('input[name="CurrencyCode"]')||{}).value || 'USD';
            else input.value = '';
        });
        tbody.appendChild(clone);
        wireRemove(clone);
        renumber();
    });
})();
</script>
