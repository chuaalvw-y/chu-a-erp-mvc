@model ChuA.ERP.Web.Mvc.ViewModels.JournalEntries.JournalEntryListViewModel
@{
    ViewData["Title"] = "Journal entries";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Journal entries</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="JournalEntryRead">+ New entry</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="fiscalPeriodId" value="@(Model.FiscalPeriodId?.ToString())" class="form-control" placeholder="Fiscal period id (optional)" />
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
            <option value="Posted" selected="@(Model.Status == "Posted")">Posted</option>
            <option value="Reversed" selected="@(Model.Status == "Reversed")">Reversed</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No journal entries match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Entry #</th><th>Entry date</th><th>Currency</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th>Status</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var e in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@e.Id">@e.EntryNumber</a></td>
                    <td>@e.EntryDate.ToString("yyyy-MM-dd")</td>
                    <td>@e.CurrencyCode</td>
                    <td class="text-end">@e.TotalDebit.ToString("N2")</td>
                    <td class="text-end">@e.TotalCredit.ToString("N2")</td>
                    <td>@Html.StatusBadge(e.Status)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@e.Id">View</a>
                        @if (string.Equals(e.Status, "Draft", StringComparison.OrdinalIgnoreCase))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@e.Id">Edit</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
