@model PurchaseOrderDto
@{
    ViewData["Title"] = "Approve purchase order";
}
<h1 class="h3 mb-4">Approve purchase order</h1>
<div class="alert alert-info">
    Approving will move PO <strong>@Model.OrderNumber</strong> from <em>Draft</em> to <em>Approved</em>.
    Lines and totals will be locked from further edits.
</div>

<dl class="row">
    <dt class="col-sm-3">PO id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Order number</dt><dd class="col-sm-9">@Model.OrderNumber</dd>
    <dt class="col-sm-3">Vendor</dt><dd class="col-sm-9"><code>@Model.VendorId</code></dd>
    <dt class="col-sm-3">Total</dt><dd class="col-sm-9"><strong>@Html.Money(Model.TotalAmount)</strong></dd>
    <dt class="col-sm-3">Current status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
</dl>

<form asp-action="Approve" asp-route-id="@Model.Id" method="post" data-confirm="Approve this purchase order?">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-success">Approve purchase order</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
</form>
