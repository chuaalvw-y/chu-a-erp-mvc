@model PurchaseOrderDto
@{
    ViewData["Title"] = $"PO {Model.OrderNumber}";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Purchase order @Model.OrderNumber @Html.StatusBadge(Model.Status)</h1>
    <div>
        <a class="btn btn-outline-success" asp-action="Approve" asp-route-id="@Model.Id" asp-authorize-policy="PurchaseOrderApprove">Approve</a>
        <a class="btn btn-outline-primary" asp-action="Receive" asp-route-id="@Model.Id" asp-authorize-policy="PurchaseOrderReceive">Receive goods</a>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="PurchaseOrderUpdate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="PurchaseOrderDelete">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">PO id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Vendor id</dt><dd class="col-sm-9"><code>@Model.VendorId</code></dd>
    <dt class="col-sm-3">Order number</dt><dd class="col-sm-9">@Model.OrderNumber</dd>
    <dt class="col-sm-3">Order date</dt><dd class="col-sm-9">@Model.OrderDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.CurrencyCode</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
    <dt class="col-sm-3">Total</dt><dd class="col-sm-9"><strong>@Html.Money(Model.TotalAmount)</strong></dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
