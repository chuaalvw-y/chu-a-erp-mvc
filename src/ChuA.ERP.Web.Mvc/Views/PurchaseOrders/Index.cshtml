@model ChuA.ERP.Web.Mvc.ViewModels.PurchaseOrders.PurchaseOrderListViewModel
@{
    ViewData["Title"] = "Purchase orders";
}
<partial name="_PageHeader" model='@(new PageHeaderViewModel { Title = "Purchase orders", Actions = new[] { new PageHeaderActionViewModel { Text = "New purchase order", Url = Url.Action("Create")!, Policy = AuthorizationPolicies.PurchaseOrderCreate, IconCssClass = "bi bi-plus-lg" } } })' />

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search order number..." />
    </div>
    <div class="col-md-3">
        <select name="vendorId" class="form-select" aria-label="Vendor">
            <option value="">All vendors</option>
            @foreach (var vendor in Model.Vendors)
            {
                <option value="@vendor.Id" selected="@(Model.VendorId == vendor.Id)">@vendor.VendorCode - @vendor.LegalName</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <input type="text" name="status" value="@Model.Status" class="form-control" placeholder="Status" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No purchase orders match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Order #</th><th>Vendor</th><th>Order date</th><th>Currency</th><th>Status</th><th class="text-end">Total</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var po in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@po.Id">@po.OrderNumber</a></td>
                    <td>@(Model.Vendors.FirstOrDefault(v => v.Id == po.VendorId)?.LegalName ?? po.VendorId.ToString())</td>
                    <td>@po.OrderDate.ToString("yyyy-MM-dd")</td>
                    <td>@po.CurrencyCode</td>
                    <td>@Html.StatusBadge(po.Status)</td>
                    <td class="text-end">@Html.Money(po.TotalAmount)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@po.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@po.Id" asp-authorize-policy="PurchaseOrderUpdate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
