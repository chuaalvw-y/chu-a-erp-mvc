@model ChuA.ERP.Web.Mvc.ViewModels.Reports.ReportRunViewModel
@{
    ViewData["Title"] = Model.Name ?? Model.Code;
}
<div class="mb-3">
    <h1 class="h3 mb-1">@(Model.Name ?? Model.Code) <small class="text-muted">@Model.Code</small></h1>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="text-muted mb-0">@Model.Description</p>
    }
</div>

<form asp-action="Run" asp-route-code="@Model.Code" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <input type="hidden" asp-for="Code" />
    <input type="hidden" asp-for="Name" />
    <input type="hidden" asp-for="Description" />
    <div class="mb-3">
        <label asp-for="ParametersJson" class="form-label"></label>
        <textarea asp-for="ParametersJson" rows="6" class="form-control font-monospace"></textarea>
        <span asp-validation-for="ParametersJson" class="text-danger"></span>
    </div>
    <div>
        <button type="submit" class="btn btn-primary">Run report</button>
        <a asp-action="Index" class="btn btn-link">Back to reports</a>
    </div>
</form>

@if (Model.Results is not null)
{
    <hr class="my-4" />
    <h2 class="h4 mb-3">Results</h2>
    @if (Model.Results.Count == 0)
    {
        @Html.EmptyState("No rows returned by the report.")
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead><tr>
                    <th>Doc type</th>
                    <th>Doc number</th>
                    <th>Doc date</th>
                    <th>Due date</th>
                    <th>Counterparty</th>
                    <th>Currency</th>
                    <th class="text-end">Total amount</th>
                    <th class="text-end">Outstanding</th>
                    <th>Status</th>
                </tr></thead>
                <tbody>
                @foreach (var row in Model.Results)
                {
                    <tr>
                        <td>@row.DocumentType</td>
                        <td>@row.DocumentNumber</td>
                        <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@(row.DueDate.HasValue ? row.DueDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                        <td>@row.CounterpartyCode &mdash; @row.CounterpartyName</td>
                        <td>@row.CurrencyCode</td>
                        <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                        <td class="text-end">@row.OutstandingAmount.ToString("N2")</td>
                        <td>@Html.StatusBadge(row.Status.ToString())</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
}

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
