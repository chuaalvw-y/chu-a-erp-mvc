@model RoleDto
@{
    ViewData["Title"] = Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Name</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Role id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Html.StatusBadge(Model.IsSystemRole ? "System" : "Custom")</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
