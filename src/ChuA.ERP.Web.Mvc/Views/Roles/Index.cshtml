@model ChuA.ERP.Web.Mvc.ViewModels.Roles.RoleListViewModel
@{
    ViewData["Title"] = "Roles";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Roles</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-role="SystemAdmin,CompanyAdmin">+ New role</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No roles match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Name</th><th>Description</th><th>Type</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var r in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@r.Id">@r.Name</a></td>
                    <td>@r.Description</td>
                    <td>@Html.StatusBadge(r.IsSystemRole ? "System" : "Custom")</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@r.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
