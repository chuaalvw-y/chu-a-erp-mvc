@model SalesOrderDto
@{
    ViewData["Title"] = "Delete sales order";
}
<h1 class="h3 mb-4 text-danger">Delete sales order</h1>
<div class="alert alert-danger">
    <strong>This action cannot be undone.</strong> Confirm you want to delete sales order <strong>@Model.OrderNumber</strong>.
</div>

<dl class="row">
    <dt class="col-sm-3">SO id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Order number</dt><dd class="col-sm-9">@Model.OrderNumber</dd>
    <dt class="col-sm-3">Customer</dt><dd class="col-sm-9"><code>@Model.CustomerId</code></dd>
    <dt class="col-sm-3">Total</dt><dd class="col-sm-9">@Html.Money(Model.TotalAmount)</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" data-confirm="Delete this sales order? This cannot be undone.">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete sales order</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
</form>
