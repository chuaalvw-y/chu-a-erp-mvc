@model SalesOrderDto
@{
    ViewData["Title"] = $"SO {Model.OrderNumber}";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Sales order @Model.OrderNumber @Html.StatusBadge(Model.Status)</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Ship" asp-route-id="@Model.Id" asp-authorize-policy="SalesOrderShip">Ship</a>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-policy="SalesOrderUpdate">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-policy="SalesOrderDelete">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">SO id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Customer id</dt><dd class="col-sm-9"><code>@Model.CustomerId</code></dd>
    <dt class="col-sm-3">Order number</dt><dd class="col-sm-9">@Model.OrderNumber</dd>
    <dt class="col-sm-3">Order date</dt><dd class="col-sm-9">@Model.OrderDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Requested ship</dt><dd class="col-sm-9">@(Model.RequestedShipDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
    <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.CurrencyCode</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
    <dt class="col-sm-3">Total</dt><dd class="col-sm-9"><strong>@Html.Money(Model.TotalAmount)</strong></dd>
</dl>

@if (Model.Lines?.Count > 0)
{
    <h2 class="h5 mt-4">Lines</h2>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Item</th><th>Description</th><th>Ordered</th><th>Shipped</th><th>Unit price</th><th>Total</th></tr></thead>
            <tbody>
            @foreach (var line in Model.Lines)
            {
                <tr>
                    <td><code>@line.ItemId</code></td>
                    <td>@line.Description</td>
                    <td>@line.OrderedQuantity.Value @line.OrderedQuantity.UnitOfMeasure</td>
                    <td>@line.ShippedQuantity.Value @line.ShippedQuantity.UnitOfMeasure</td>
                    <td>@Html.Money(line.UnitPrice)</td>
                    <td>@Html.Money(line.LineTotal)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
