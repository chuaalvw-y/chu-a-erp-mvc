@model ChuA.ERP.Web.Mvc.ViewModels.SalesOrders.SalesOrderListViewModel
@{
    ViewData["Title"] = "Sales orders";
}
<partial name="_PageHeader" model='@(new PageHeaderViewModel { Title = "Sales orders", Actions = new[] { new PageHeaderActionViewModel { Text = "New sales order", Url = Url.Action("Create")!, Policy = AuthorizationPolicies.SalesOrderCreate, IconCssClass = "bi bi-plus-lg" } } })' />

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search order number..." />
    </div>
    <div class="col-md-3">
        <select name="customerId" class="form-select" aria-label="Customer">
            <option value="">All customers</option>
            @foreach (var customer in Model.Customers)
            {
                <option value="@customer.Id" selected="@(Model.CustomerId == customer.Id)">@customer.CustomerCode - @customer.LegalName</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <input type="text" name="status" value="@Model.Status" class="form-control" placeholder="Status" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
    </div>
</form>

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No sales orders match your filters yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Order #</th><th>Customer</th><th>Order date</th><th>Currency</th><th>Status</th><th class="text-end">Total</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var so in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@so.Id">@so.OrderNumber</a></td>
                    <td>@(Model.Customers.FirstOrDefault(c => c.Id == so.CustomerId)?.LegalName ?? so.CustomerId.ToString())</td>
                    <td>@so.OrderDate.ToString("yyyy-MM-dd")</td>
                    <td>@so.CurrencyCode</td>
                    <td>@Html.StatusBadge(so.Status)</td>
                    <td class="text-end">@Html.Money(so.TotalAmount)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@so.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@so.Id" asp-authorize-policy="sales-order:update">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
