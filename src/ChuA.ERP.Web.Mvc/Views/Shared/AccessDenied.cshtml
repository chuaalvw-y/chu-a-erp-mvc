@{
    ViewData["Title"] = "Access denied";
}
<div class="card border-warning">
    <div class="card-header bg-warning">
        <h1 class="h4 mb-0">Access denied</h1>
    </div>
    <div class="card-body">
        <p>You don't have permission to view this resource.</p>
        <p class="text-muted small">If you believe this is a mistake, please contact your system administrator.</p>
    </div>
    <div class="card-footer">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Return to dashboard</a>
    </div>
</div>
