@inject ICurrentUserService CurrentUser
@inject IWebHostEnvironment WebHostEnvironment
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var requestPath = Context.Request.Path.Value ?? string.Empty;

    bool IsRoute(params string[] names) =>
        names.Any(name =>
            string.Equals(controller, name, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(requestPath, "/" + name, StringComparison.OrdinalIgnoreCase) ||
            requestPath.StartsWith("/" + name + "/", StringComparison.OrdinalIgnoreCase));

    string LinkClass(params string[] names) =>
        IsRoute(names) ? "nav-link active" : "nav-link";

    var isPurchasingRoute = IsRoute("Vendors", "PurchaseOrders", "Bills");
    var isSalesRoute = IsRoute("Customers", "SalesOrders", "Invoices");
    var isInventoryRoute = IsRoute("Inventory");
    var isFinanceRoute = IsRoute("ChartOfAccounts", "JournalEntries");
    var isWorkflowRoute = IsRoute("Workflow", "WorkflowDefinitions", "WorkflowConfigurations", "WorkflowInstances", "BusinessRules");
    var isReportsRoute = IsRoute("Reports");
}
<nav class="erp-nav py-2" aria-label="Primary">
    <ul class="nav flex-column">
        <li class="nav-item">
            <a class="@LinkClass("Dashboard")" asp-area="Dashboard" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#purchasingMenu"
                    aria-expanded="@(isPurchasingRoute ? "true" : "false")"
                    aria-controls="purchasingMenu">
                Purchasing
            </button>
        </li>
        <li class="nav-item">
            <div id="purchasingMenu" class="collapse @(isPurchasingRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="vendor:view">
                        <a class="@LinkClass("Vendors")" asp-area="" asp-controller="Vendors" asp-action="Index">Vendors</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="purchase-order:view">
                        <a class="@LinkClass("PurchaseOrders")" asp-area="" asp-controller="PurchaseOrders" asp-action="Index">Purchase Orders</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="bill:view">
                        <a class="@LinkClass("Bills")" asp-area="" asp-controller="Bills" asp-action="Index">Bills</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#salesMenu"
                    aria-expanded="@(isSalesRoute ? "true" : "false")"
                    aria-controls="salesMenu">
                Sales
            </button>
        </li>
        <li class="nav-item">
            <div id="salesMenu" class="collapse @(isSalesRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="customer:view">
                        <a class="@LinkClass("Customers")" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="sales-order:view">
                        <a class="@LinkClass("SalesOrders")" asp-area="" asp-controller="SalesOrders" asp-action="Index">Sales Orders</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="invoice:view">
                        <a class="@LinkClass("Invoices")" asp-area="" asp-controller="Invoices" asp-action="Index">Invoices</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#inventoryMenu"
                    aria-expanded="@(isInventoryRoute ? "true" : "false")"
                    aria-controls="inventoryMenu">
                Inventory
            </button>
        </li>
        <li class="nav-item">
            <div id="inventoryMenu" class="collapse @(isInventoryRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="inventory:view">
                        <a class="@LinkClass("Inventory")" asp-area="" asp-controller="Inventory" asp-action="Index">Items</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="inventory:create">
                        <a class="nav-link" asp-area="" asp-controller="Inventory" asp-action="ImportDemo">Import items</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#financeMenu"
                    aria-expanded="@(isFinanceRoute ? "true" : "false")"
                    aria-controls="financeMenu">
                Finance
            </button>
        </li>
        <li class="nav-item">
            <div id="financeMenu" class="collapse @(isFinanceRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="chart-of-accounts:view">
                        <a class="@LinkClass("ChartOfAccounts")" asp-area="" asp-controller="ChartOfAccounts" asp-action="Index">Chart of Accounts</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="journal-entry:view">
                        <a class="@LinkClass("JournalEntries")" asp-area="" asp-controller="JournalEntries" asp-action="Index">Journal Entries</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#workflowMenu"
                    aria-expanded="@(isWorkflowRoute ? "true" : "false")"
                    aria-controls="workflowMenu">
                Workflow
            </button>
        </li>
        <li class="nav-item">
            <div id="workflowMenu" class="collapse @(isWorkflowRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="workflow:view">
                        <a class="@LinkClass("Workflow")" asp-area="" asp-controller="Workflow" asp-action="Index">My approvals</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="workflow:view">
                        <a class="@LinkClass("WorkflowDefinitions")" asp-area="" asp-controller="WorkflowDefinitions" asp-action="Index">Definitions</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="workflow:view">
                        <a class="@LinkClass("WorkflowConfigurations")" asp-area="" asp-controller="WorkflowConfigurations" asp-action="Index">Configurations</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="workflow:view">
                        <a class="@LinkClass("WorkflowInstances")" asp-area="" asp-controller="WorkflowInstances" asp-action="Index">Instances</a>
                    </li>
                    <li class="nav-item" asp-authorize-policy="business-rule:view">
                        <a class="@LinkClass("BusinessRules")" asp-area="" asp-controller="BusinessRules" asp-action="Index">Business rules</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section px-3 pt-3">
            <button class="btn btn-link nav-section-collapse-toggle text-uppercase small text-muted p-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#reportsMenu"
                    aria-expanded="@(isReportsRoute ? "true" : "false")"
                    aria-controls="reportsMenu">
                Reports
            </button>
        </li>
        <li class="nav-item">
            <div id="reportsMenu" class="collapse @(isReportsRoute ? "show" : string.Empty)">
                <ul class="nav flex-column">
                    <li class="nav-item" asp-authorize-policy="reports:view">
                        <a class="@LinkClass("Reports")" asp-area="" asp-controller="Reports" asp-action="Index">Reports</a>
                    </li>
                </ul>
            </div>
        </li>

        <li class="nav-section text-uppercase small text-muted px-3 pt-3" asp-authorize-role="SystemAdmin,CompanyAdmin">Administration</li>
        <li class="nav-item" asp-authorize-role="SystemAdmin">
            <a class="@LinkClass("Companies")" asp-area="" asp-controller="Companies" asp-action="Index">Companies</a>
        </li>
        <li class="nav-item" asp-authorize-role="SystemAdmin,CompanyAdmin">
            <a class="@LinkClass("Users")" asp-area="" asp-controller="Users" asp-action="Index">Users</a>
        </li>
        <li class="nav-item" asp-authorize-role="SystemAdmin,CompanyAdmin">
            <a class="@LinkClass("Roles")" asp-area="" asp-controller="Roles" asp-action="Index">Roles</a>
        </li>

        <li class="nav-section text-uppercase small text-muted px-3 pt-3">System</li>
        <li class="nav-item">
            <a class="@LinkClass("Health")" asp-area="" asp-controller="Health" asp-action="Index">System Health</a>
        </li>

        @if (WebHostEnvironment.IsDevelopment())
        {
            <li class="nav-section text-uppercase small text-muted px-3 pt-3">Development</li>
            <li class="nav-item">
                <a class="@LinkClass("AuthDebug")" asp-area="" asp-controller="AuthDebug" asp-action="Index" title="Inspect the current user's claims, roles, permissions, and scopes (Development only)">
                    <i class="bi bi-bug-fill me-1"></i>Auth Debug
                </a>
            </li>
        }
    </ul>
</nav>
