@using ChuA.ERP.Web.Mvc.Contracts.Common
@using ChuA.ERP.Web.Mvc.ViewModels
@model IPagedResult
@{
    var pager = PagerViewModel.FromQuery(Model, Context.Request.Query);
    int current = pager.PageNumber;
    int total = pager.TotalPages;
    if (total <= 1) { return; }
}
<nav aria-label="pagination" class="mt-3">
    <ul class="pagination">
        <li class="page-item @(current <= 1 ? "disabled" : "")">
            <a class="page-link" href="@pager.UrlFor(Math.Max(1, current - 1))">Previous</a>
        </li>
        @for (int p = Math.Max(1, current - 2); p <= Math.Min(total, current + 2); p++)
        {
            <li class="page-item @(p == current ? "active" : "")">
                <a class="page-link" href="@pager.UrlFor(p)">@p</a>
            </li>
        }
        <li class="page-item @(current >= total ? "disabled" : "")">
            <a class="page-link" href="@pager.UrlFor(Math.Min(total, current + 1))">Next</a>
        </li>
    </ul>
</nav>
