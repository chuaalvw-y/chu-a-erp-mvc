@{
    var toasts = TempData.ConsumeToasts();
}
@if (toasts.Count > 0)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
        @foreach (var toast in toasts)
        {
            var (bg, icon) = toast.Level switch
            {
                ToastLevel.Success => ("success", "&#10003;"),
                ToastLevel.Warning => ("warning", "!"),
                ToastLevel.Error   => ("danger", "&#10006;"),
                _                  => ("info", "&#9432;"),
            };
            <div class="toast align-items-center text-bg-@bg border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <strong class="me-1">@Html.Raw(icon)</strong>
                        @if (!string.IsNullOrEmpty(toast.Title))
                        {
                            <strong class="me-1">@toast.Title</strong>
                        }
                        @toast.Text
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>
}
