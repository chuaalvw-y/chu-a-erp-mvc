@model UserDto
@{
    ViewData["Title"] = Model.UserName;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.FirstName @Model.LastName <small class="text-muted">@Model.UserName</small></h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Delete</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">User id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">User name</dt><dd class="col-sm-9">@Model.UserName</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">First name</dt><dd class="col-sm-9">@Model.FirstName</dd>
    <dt class="col-sm-3">Last name</dt><dd class="col-sm-9">@Model.LastName</dd>
    <dt class="col-sm-3">Employee id</dt><dd class="col-sm-9">@(Model.EmployeeId is null ? "-" : Model.EmployeeId.ToString())</dd>
    <dt class="col-sm-3">Email confirmed</dt><dd class="col-sm-9">@Html.StatusBadge(Model.EmailConfirmed ? "Confirmed" : "Pending")</dd>
    <dt class="col-sm-3">Two-factor</dt><dd class="col-sm-9">@Html.StatusBadge(Model.TwoFactorEnabled ? "Enabled" : "Disabled")</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
