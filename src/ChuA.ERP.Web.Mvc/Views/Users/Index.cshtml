@model ChuA.ERP.Web.Mvc.ViewModels.Users.UserListViewModel
@{
    ViewData["Title"] = "Users";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Users</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-role="SystemAdmin,CompanyAdmin">+ New user</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No users match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>User name</th><th>Email</th><th>Full name</th><th>Email confirmed</th><th>2FA</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var u in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@u.Id">@u.UserName</a></td>
                    <td>@u.Email</td>
                    <td>@u.FirstName @u.LastName</td>
                    <td>@Html.StatusBadge(u.EmailConfirmed ? "Confirmed" : "Pending")</td>
                    <td>@Html.StatusBadge(u.TwoFactorEnabled ? "Enabled" : "Disabled")</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@u.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id" asp-authorize-role="SystemAdmin,CompanyAdmin">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
