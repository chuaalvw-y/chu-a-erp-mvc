@model ChuA.ERP.Web.Mvc.ViewModels.Vendors.VendorListViewModel
@{
    ViewData["Title"] = "Vendors";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Vendors</h1>
    <a asp-action="Create" class="btn btn-primary" asp-authorize-policy="VendorCreate">+ New vendor</a>
</div>

<partial name="_SearchBox" model="Model.Search" />

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No vendors match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Code</th><th>Legal name</th><th>Currency</th><th>Terms</th><th>Status</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var v in Model.Page.Items)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@v.Id">@v.VendorCode</a></td>
                    <td>@v.LegalName</td>
                    <td>@v.DefaultCurrencyCode</td>
                    <td>@v.PaymentTermsDays days</td>
                    <td>@Html.StatusBadge(v.IsBlocked ? "Blocked" : "Active")</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@v.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@v.Id" asp-authorize-policy="VendorUpdate">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
