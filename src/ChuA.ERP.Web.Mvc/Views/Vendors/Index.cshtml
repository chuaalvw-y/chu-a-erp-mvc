@model ChuA.ERP.Web.Mvc.ViewModels.Vendors.VendorListViewModel
@{
    ViewData["Title"] = "Vendors";
    var newVendorModalUrl = Url.Action("CreateModal", "Vendors");
}

@* "New vendor" link is the no-JS fallback (navigates to /Vendors/Create). chua-vendors.js
   intercepts clicks on .js-vendor-create and fetches the modal partial instead. *@
<partial name="_PageHeader" model='@(new PageHeaderViewModel {
    Title = "Vendors",
    Actions = new[]
    {
        new PageHeaderActionViewModel
        {
            Text = "New vendor",
            Url = Url.Action("Create") ?? "#",
            CssClass = "btn btn-primary js-vendor-create",
            Policy = AuthorizationPolicies.VendorCreate,
            IconCssClass = "bi bi-plus-lg",
        }
    }
})' />

<partial name="_SearchBox" model="Model.Search" />

<div id="vendors-rows-container"
     data-rows-url="@Url.Action("IndexPartial", "Vendors")"
     data-current-search="@(Model.Search ?? string.Empty)">
    <partial name="_VendorRowsPartial" model="Model" />
</div>

@* Empty placeholder — chua-vendors.js injects the modal HTML here and uses Bootstrap to show it. *@
<div class="modal fade" id="vendor-modal-host" tabindex="-1" aria-hidden="true" aria-labelledby="vendor-modal-host"></div>

@section Scripts {
    <script src="~/js/chua-vendors.js" asp-append-version="true"></script>
}
