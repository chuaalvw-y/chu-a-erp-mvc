    Table-body + pager partial. Rendered as part of Index and as the response of
    /Vendors/IndexPartial so chua-vendors.js can refresh just the table when search,
    page or sort changes — preserving the shell, breadcrumbs, and search box state.
*@

@model ChuA.ERP.Web.Mvc.ViewModels.Vendors.VendorListViewModel

@if (Model.Page.Items.Count == 0)
{
    @Html.EmptyState("No vendors match your search yet.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover" id="vendors-table">
            <thead><tr>
                <th>Code</th><th>Legal name</th><th>Currency</th><th>Terms</th><th>Status</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var v in Model.Page.Items)
            {
                <partial name="_VendorRow" model="v" />
            }
            </tbody>
        </table>
    </div>
    <partial name="_Pager" model="Model.Page" />
}
