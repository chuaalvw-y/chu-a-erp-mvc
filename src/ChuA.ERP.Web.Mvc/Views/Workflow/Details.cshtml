@model ApprovalRequestDto
@{
    ViewData["Title"] = $"Workflow task — {Model.SubjectType}";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.SubjectType approval @Html.StatusBadge(Model.Status)</h1>
    <div>
        <a class="btn btn-outline-success" asp-action="Submit" asp-route-id="@Model.Id" asp-authorize-policy="WorkflowApprovalSubmit">Approve / Reject</a>
        <a class="btn btn-outline-primary" asp-action="Reassign" asp-route-id="@Model.Id" asp-authorize-policy="WorkflowReassign">Reassign</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Request id</dt><dd class="col-sm-9"><code>@Model.Id</code></dd>
    <dt class="col-sm-3">Company id</dt><dd class="col-sm-9"><code>@Model.CompanyId</code></dd>
    <dt class="col-sm-3">Subject type</dt><dd class="col-sm-9">@Model.SubjectType</dd>
    <dt class="col-sm-3">Subject id</dt><dd class="col-sm-9"><code>@Model.SubjectId</code></dd>
    <dt class="col-sm-3">Requested by</dt><dd class="col-sm-9">@Model.RequestedBy</dd>
    <dt class="col-sm-3">Requested at</dt><dd class="col-sm-9">@Model.RequestedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</dd>
    <dt class="col-sm-3">Required approvals</dt><dd class="col-sm-9">@Model.RequiredApprovals</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Html.StatusBadge(Model.Status)</dd>
</dl>

<a asp-action="Index" class="btn btn-link">&larr; Back to list</a>
