@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.ReassignFormViewModel
@{
    ViewData["Title"] = "Reassign workflow approval";
    var task = ViewData["Task"] as WorkflowApprovalDto;
}
<h1 class="h3 mb-4">Reassign approval</h1>

@if (task is not null)
{
    <dl class="row">
        <dt class="col-sm-3">Approval id</dt><dd class="col-sm-9"><code>@task.Id</code></dd>
        <dt class="col-sm-3">Step</dt><dd class="col-sm-9">@task.StepNumber</dd>
        <dt class="col-sm-3">Currently assigned to</dt><dd class="col-sm-9"><code>@task.AssignedUserId</code></dd>
        <dt class="col-sm-3">Current status</dt><dd class="col-sm-9">@Html.StatusBadge(task.Decision)</dd>
    </dl>
}

<form asp-action="Reassign" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="InstanceId" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="ToUserId" class="form-label"></label>
            <input asp-for="ToUserId" class="form-control" placeholder="User GUID" />
            <span asp-validation-for="ToUserId" class="text-danger"></span>
        </div>
        <div class="col-md-12">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control" rows="3" maxlength="500"></textarea>
            <span asp-validation-for="Reason" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Reassign approval</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
