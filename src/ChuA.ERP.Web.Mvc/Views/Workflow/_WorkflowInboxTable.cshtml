    Reactive partial: the table body of the Workflow Inbox. Rendered both as part of the
    full Index view AND on its own via Controller.PartialOrView() so chua-reactive.js can
    fetch it after a user action or a workflowInboxChanged SignalR event without reloading
    the surrounding shell (sidebar, breadcrumbs, etc.).
*@

@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.WorkflowListViewModel

@if (Model.Tasks.Count == 0)
{
    @Html.EmptyState("No pending workflow approvals assigned to you.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover" id="workflow-inbox-table">
            <thead><tr>
                <th>Approval id</th><th>Instance</th><th>Step</th><th>Assigned</th><th>Due</th><th>Status</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var t in Model.Tasks)
            {
                <tr data-approval-id="@t.Id">
                    <td><a asp-action="Details" asp-route-id="@t.Id"><code>@t.Id.ToString()[..8]</code></a></td>
                    <td><code>@t.WorkflowInstanceId.ToString()[..8]</code></td>
                    <td>@t.StepNumber</td>
                    <td>@t.AssignedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(t.DueAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                    <td>@Html.StatusBadge(t.Decision)</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@t.Id">View</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
