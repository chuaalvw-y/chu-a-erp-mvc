@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.ConfigureWorkflowFormViewModel
@{ ViewData["Title"] = "Configure workflow"; }
<h1 class="h3 mb-4">Configure workflow</h1>

<form asp-action="Create" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="TargetEntityType" class="form-label"></label>
            <input asp-for="TargetEntityType" class="form-control" placeholder="e.g. Bill" />
            <span asp-validation-for="TargetEntityType" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="WorkflowCode" class="form-label"></label>
            <input asp-for="WorkflowCode" class="form-control" placeholder="e.g. BillApproval" />
            <span asp-validation-for="WorkflowCode" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="PinnedVersion" class="form-label"></label>
            <input asp-for="PinnedVersion" class="form-control" />
            <span asp-validation-for="PinnedVersion" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
