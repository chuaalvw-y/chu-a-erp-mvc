@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.ChangeWorkflowConfigurationFormViewModel
@{ ViewData["Title"] = $"Edit configuration — {Model.TargetEntityType}"; }
<h1 class="h3 mb-4">Edit configuration — @Model.TargetEntityType</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TargetEntityType" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="WorkflowCode" class="form-label"></label>
            <input asp-for="WorkflowCode" class="form-control" />
            <span asp-validation-for="WorkflowCode" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="PinnedVersion" class="form-label"></label>
            <input asp-for="PinnedVersion" class="form-control" />
            <span asp-validation-for="PinnedVersion" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
