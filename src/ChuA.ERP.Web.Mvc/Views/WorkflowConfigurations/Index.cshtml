@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.WorkflowConfigurationListViewModel
@{ ViewData["Title"] = "Workflow configurations"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Workflow configurations</h1>
    <a class="btn btn-primary" asp-action="Create" asp-authorize-policy="WorkflowConfigManage">+ New configuration</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label class="form-label" for="targetEntityType">Target entity</label>
        <input id="targetEntityType" name="targetEntityType" value="@Model.TargetEntityType" class="form-control" placeholder="e.g. Bill" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
    </div>
</form>

@if (Model.Configurations.Count == 0)
{
    @Html.EmptyState("No workflow configurations. Configure a document type to opt it into the workflow engine.")
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead><tr>
                <th>Target entity</th><th>Workflow code</th><th>Pinned version</th><th>Active</th><th class="actions">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var c in Model.Configurations)
            {
                <tr>
                    <td>@c.TargetEntityType</td>
                    <td>@c.WorkflowCode</td>
                    <td>@(c.PinnedVersion?.ToString() ?? "latest Published")</td>
                    <td>@(c.IsActive ? Html.Raw("<span class=\"badge bg-success\">Active</span>") : Html.Raw("<span class=\"badge bg-secondary\">Inactive</span>"))</td>
                    <td class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.Id" asp-authorize-policy="WorkflowConfigManage">Edit</a>
                        @if (c.IsActive)
                        {
                            <form asp-action="Deactivate" asp-route-id="@c.Id" method="post" class="d-inline" asp-authorize-policy="WorkflowConfigManage">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-warning" type="submit">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Activate" asp-route-id="@c.Id" method="post" class="d-inline" asp-authorize-policy="WorkflowConfigManage">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
