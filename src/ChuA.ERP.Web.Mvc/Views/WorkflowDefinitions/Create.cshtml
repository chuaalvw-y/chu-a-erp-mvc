@model ChuA.ERP.Web.Mvc.ViewModels.Workflow.CreateWorkflowDefinitionFormViewModel
@{ ViewData["Title"] = "New workflow definition"; }
<h1 class="h3 mb-4">New workflow definition</h1>

<form asp-action="Create" method="post" novalidate>
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" placeholder="e.g. BillApproval" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="TargetEntityType" class="form-label"></label>
            <input asp-for="TargetEntityType" class="form-control" placeholder="e.g. Bill" />
            <span asp-validation-for="TargetEntityType" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Version" class="form-label"></label>
            <input asp-for="Version" class="form-control" />
            <span asp-validation-for="Version" class="text-danger"></span>
        </div>
        <div class="col-md-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3" maxlength="1000"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-md-12 form-check">
            <input asp-for="SystemWide" class="form-check-input" />
            <label asp-for="SystemWide" class="form-check-label"></label>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Create draft</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
