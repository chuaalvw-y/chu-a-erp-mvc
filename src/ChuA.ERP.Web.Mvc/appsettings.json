{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Api": {
    "BaseUrl": "https://localhost:5001",
    "Version": "v1",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "UseAuthBypass": true,
    "DevelopmentBearerToken": null
  },
  "Oidc": {
    "Enabled": false,
    "Authority": "",
    "ClientId": "",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "Scopes": [ "openid", "profile", "email", "chua-erp-api" ],
    "ApiAudience": "chua-erp-api",
    "RequireHttpsMetadata": true
  },
  "AppEnvironment": {
    "Label": "DEV",
    "BadgeColor": "warning",
    "ProductName": "ChuA ERP"
  }
}
