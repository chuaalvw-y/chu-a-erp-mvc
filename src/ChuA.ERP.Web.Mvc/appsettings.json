{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/chua-erp-web-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Api": {
    "BaseUrl": "https://localhost:53740",
    "Version": "v1",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "UseAuthBypass": false,
    "DevelopmentBearerToken": null
  },
  "ChuAAuthentication": {
    "DefaultProvider": "Auth0",
    "EnableClaimsTransformation": true,
    "RequireAuthenticatedUserByDefault": false,
    "NameClaimType": "preferred_username",
    "RoleClaimType": "role",
    "Providers": {
      "Auth0": {
        "Type": "Auth0WebApp",
        "Scheme": "OpenIdConnect",
        "CookieScheme": "Cookies",
        "_DomainNote": "Auth0 tenant domain, e.g. dev-xxxx.us.auth0.com. Leave blank in Development to keep DevLogin as the sign-in path.",
        "Domain": "",
        "_ClientIdNote": "Auth0 application Client ID. Empty value keeps cookie-only mode; set per environment via user-secrets or env var.",
        "ClientId": "",
        "_ClientSecretNote": "Never commit a real Client Secret. Use dotnet user-secrets in dev and a secret store in higher environments.",
        "ClientSecret": "",
        "CallbackPath": "/signin-oidc",
        "SignedOutCallbackPath": "/signout-callback-oidc",
        "Scopes": [ "openid", "profile", "email" ],
        "Audience": "chua-erp-api",
        "RequireHttpsMetadata": true,
        "UsePkce": true,
        "SaveTokens": true,
        "GetClaimsFromUserInfoEndpoint": true
      }
    }
  },
  "AppEnvironment": {
    "Label": "DEV",
    "BadgeColor": "warning",
    "ProductName": "ChuA ERP"
  },
  "DashboardApi": {
    "BaseUrl": "https://localhost:53740/",
    "TimeoutSeconds": 30,
    "AccessTokenScheme": "Bearer",
    "PropagateUserToken": true
  },
  "DashboardUi": {
    "EnableDragAndDrop": true,
    "EnableLayoutPersistence": true,
    "WidgetRefreshIntervalSeconds": 0,
    "GridColumns": 12,
    "DefaultWidgetWidth": 4,
    "DefaultWidgetHeight": 4,
    "_SignalRNote": "Absolute URL of the API's SignalR hub. When populated, dashboard.js opens a persistent connection and listens for layoutChanged / widgetDataChanged push notifications. The path '/hubs/dashboard' is the framework's default (DashboardSignalRExtensions.DefaultHubRoute). Leave null to disable real-time push and fall back to the polling refresh interval above.",
    "SignalRHubUrl": "https://localhost:53740/hubs/dashboard"
  }

}
